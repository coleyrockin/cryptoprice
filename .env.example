# All environment variables are OPTIONAL.
# The app runs fully without any configuration — data providers used
# (Stooq, Frankfurter, CoinPaprika) require no API keys.

# Optional provider override. If set, this must remain the exact HTTPS CoinPaprika origin.
COINPAPRIKA_BASE_URL=https://api.coinpaprika.com

# Cache tuning (all seconds)
CACHE_TTL_SEC=30
FALLBACK_TTL_SEC=600
STALE_ALERT_SEC=300

# Optional durable cache (Upstash / Vercel KV REST)
KV_REST_API_URL=
KV_REST_API_TOKEN=
DURABLE_CACHE_KEY=wap:dashboard:payload

# Optional logo-proxy security / rate-limit tuning
LOGO_ALLOWED_HOSTS=static.coinpaprika.com,cryptoicons.org,cryptoicon-api.pages.dev,financialmodelingprep.com,images.financialmodelingprep.com,flagcdn.com
LOGO_PROXY_TIMEOUT_MS=5000
LOGO_PROXY_MAX_BYTES=512000
LOGO_PROXY_RATE_LIMIT_PER_MIN=60
TRUST_PROXY_HEADERS=false

# Optional client-error endpoint tuning
CLIENT_ERROR_MAX_BYTES=8192
CLIENT_ERROR_RATE_LIMIT_PER_MIN=30

{
  "name": "cryptoprice",
  "private": true,
  "version": "0.1.0",
  "description": "Black-market style crypto dashboard for top 10 coins plus Midnight Token (NIGHT).",
  "author": "Cryptoprice Maintainers",
  "license": "MIT",
  "keywords": [
    "crypto",
    "dashboard",
    "react",
    "vite",
    "night",
    "midnight-token",
    "recharts"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/coleyrockin/cryptoprice.git"
  },
  "bugs": {
    "url": "https://github.com/coleyrockin/cryptoprice/issues"
  },
  "homepage": "https://github.com/coleyrockin/cryptoprice",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.2",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.server.json",
    "build": "npm run typecheck && vite build --config vite.config.ts",
    "check": "npm run build",
    "preview": "vite preview --config vite.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  }
}

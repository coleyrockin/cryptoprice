{
  "name": "world-asset-prices",
  "private": true,
  "version": "1.0.0",
  "description": "Live financial dashboard tracking the top 10 stocks, ETFs, fiat currencies, and cryptocurrencies side-by-side, plus a dedicated Midnight Token panel. Zero API keys required — powered by Stooq, Frankfurter, and CoinPaprika behind a tiered cache with bundled fallback.",
  "author": "Boyd Roberts",
  "license": "MIT",
  "keywords": [
    "stocks",
    "etfs",
    "currencies",
    "forex",
    "crypto",
    "dashboard",
    "finance",
    "vercel",
    "serverless",
    "typescript",
    "react",
    "vite",
    "tailwindcss",
    "midnight-token"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/coleyrockin/world-asset-prices.git"
  },
  "bugs": {
    "url": "https://github.com/coleyrockin/world-asset-prices/issues"
  },
  "homepage": "https://world-asset-prices.vercel.app",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.2",
  "type": "module",
  "scripts": {
    "dev": "vite --config vite.config.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run src server",
    "test:routes": "vitest run api",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.server.json",
    "build": "npm run typecheck && vite build --config vite.config.ts",
    "check:bundle": "node ./scripts/check-bundle.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run test:routes && npm run build && npm run check:bundle",
    "preview": "vite preview --config vite.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
